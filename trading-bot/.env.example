# ── Alpaca API ────────────────────────────────────────────────────────────────
# Sign up free at https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # keep this for paper trading

# ── Watchlist ─────────────────────────────────────────────────────────────────
# Comma-separated list of stock tickers to watch (no spaces)
WATCHLIST=AAPL,AMD,DDOG,SNOW,QCOM,NVDA,META,PLTR,MU

# ── Risk parameters ───────────────────────────────────────────────────────────
POSITION_SIZE_PCT=0.10        # 10% of cash per position
MAX_POSITIONS=4               # max open positions at once
MAX_DAILY_LOSS_PCT=0.05       # circuit breaker: stop trading after 5% portfolio loss
STOP_LOSS_PCT=0.03            # hard stop: sell if down 3% from entry
TRAILING_STOP_PCT=0.035       # trailing stop: sell if down 3.5% from peak

# ── Optional: Telegram alerts (leave blank to disable) ────────────────────────
# Set up a bot at https://t.me/BotFather to get a token
# then run: python -c "from src.notify import get_chat_id; get_chat_id()"
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: Options trading (leave false) ───────────────────────────────────
OPTIONS_ENABLED=false
